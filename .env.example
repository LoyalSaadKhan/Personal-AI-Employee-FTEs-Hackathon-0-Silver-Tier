# Obsidian Vault Path
OBSIDIAN_Vault_PATH=/path/to/AI_Employee_Vault

# Email Configuration (for Email MCP)
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# MCP Server URLs
MCP_FILESYSTEM_URL=http://localhost:8080
MCP_EMAIL_URL=http://localhost:8081
MCP_BROWSER_URL=http://localhost:8808

# Watcher Configuration
WATCHER_CHECK_INTERVAL=60

# Ralph Wiggum Loop
MAX_ITERATIONS=10

# Odoo Configuration (if using)
ODOO_URL=https://your-odoo-instance.com
ODOO_API_KEY=your-odoo-api-key

# LinkedIn Configuration (if using)
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
